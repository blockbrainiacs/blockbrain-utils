# Configuration for blockbrain_kb_upload.py — copy to .env.upload and fill in.

BB_API_URL=https://blocky.theblockbrain.ai/files/v2
BB_API_KEY=api_key_here

# Used only when a knowledge base has to be created (some tenants reject
# KB creation without an explicit embedding model).
BB_EMBEDDING_MODEL=azure-emb-3-large
BB_ENABLE_EXTRACT_IMAGE=true

# Optional overrides
BB_PARENT_PATH=root
UPLOAD_SLEEP=0.1
